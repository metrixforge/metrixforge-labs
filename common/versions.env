# Pinned versions for MetrixForge Labs. NEVER use "latest" — Killercoda envs and
# upstream projects drift; a pinned tag is the only reproducible lab.
# Source: labs/RECON-DECISIONS.md (web-verified 2026-07-20).

# --- kwok: fake node fleet (Profiles B/C) ---
KWOK_VERSION=v0.8.0
# v0.8.0 ships kwok.yaml + stage-fast.yaml ONLY (no stage.yaml — a stage.yaml ref = 404).
KWOK_RELEASE_URL=https://github.com/kubernetes-sigs/kwok/releases/download/${KWOK_VERSION}

# --- karpenter kwok provider (Profile C) — BUILD-NEEDED, no public image/chart ---
KARPENTER_KWOK_VERSION=v1.14.0
KARPENTER_KWOK_IMAGE=ghcr.io/metrixforge/karpenter-kwok:v1.14.0   # built in CI (ko), see M2-0 spike
KARPENTER_NODEPOOL_API=karpenter.sh/v1
KARPENTER_NODECLASS_API=karpenter.kwok.sh/v1alpha1               # unstable testing API — vendor CRDs from same tag

# --- OpenCost + Prometheus (Profile A only) ---
OPENCOST_HELM_REPO=https://opencost.github.io/opencost-helm-chart
OPENCOST_HELM_CHART_VERSION=2.5.27
OPENCOST_IMAGE=ghcr.io/opencost/opencost:1.120.4
PROMETHEUS_HELM_CHART=prometheus-community/kube-prometheus-stack  # TODO: pin exact version before publish

# --- Killercoda backend ---
KILLERCODA_IMAGEID=kubernetes-kubeadm-1node          # 2GB, K8s 1.34; fallback: kubernetes-kubeadm-1node-4GB
